# Authentication Configuration (Development)
# Copy this file to .env.local and fill in your values
#
# ⚠️ IMPORTANT: Client secrets are NEVER used in frontend code!
# SPAs use PKCE flow which doesn't require secrets.
# Client secrets are only for server-side Azure SWA built-in auth.

# Required: Azure AD Application (Client) ID
VITE_AUTH_CLIENT_ID=your-client-id-here

# Required: Authority URL
# Single tenant: https://login.microsoftonline.com/{tenant-id}
# Multi-tenant: https://login.microsoftonline.com/common
# B2C: https://{tenant}.b2clogin.com/{tenant}.onmicrosoft.com/{policy}
# CIAM: https://{tenant}.ciamlogin.com/
VITE_AUTH_AUTHORITY=https://login.microsoftonline.com/your-tenant-id

# Optional: Redirect URI (default: /auth/callback)
VITE_AUTH_REDIRECT_URI=/auth/callback

# Optional: Post-logout redirect URI (default: /)
VITE_AUTH_POST_LOGOUT_REDIRECT_URI=/

# Optional: OAuth scopes (comma-separated, default: openid,profile,email)
VITE_AUTH_SCOPES=openid,profile,email

# Optional: Known authorities for CIAM/B2C (comma-separated)
# VITE_AUTH_KNOWN_AUTHORITIES=login.microsoftonline.com

# ═══════════════════════════════════════════════════════════════════
# Azure Static Web App Settings (Marketplace Deployment)
# These are configured in Azure Portal App Settings, NOT in this file!
# ═══════════════════════════════════════════════════════════════════
# AAD_CLIENT_ID        = Application (Client) ID
# AAD_CLIENT_SECRET    = Client Secret (server-side only, NEVER in frontend!)
# AAD_TENANT_ID        = Directory (Tenant) ID
